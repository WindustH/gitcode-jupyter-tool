def default_chrome_bin() -> str:
    if os.environ.get("CHROME"):
        return os.environ["CHROME"]
    bundled = pathlib.Path("/opt/google/chrome/google-chrome")
    if bundled.exists():
        return str(bundled)
    return "google-chrome-stable"


class JupyterdError(RuntimeError):
    pass


CHROME_PROCESS: subprocess.Popen[Any] | None = None


def log(message: str) -> None:
    timestamp = dt.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    print(f"[{timestamp}] {message}", flush=True)


def eprint(message: str) -> None:
    print(message, file=sys.stderr)


def fetch_targets(cdp_list_url: str) -> list[dict[str, Any]]:
    data = JUPYTER_SH.fetch_json(cdp_list_url, timeout=5.0)
    if not isinstance(data, list):
        raise JupyterdError(f"unexpected Chrome DevTools target list: {data!r}")
    return data


def cdp_base_url(cdp_list_url: str) -> str:
    parsed = urllib.parse.urlparse(cdp_list_url)
    return urllib.parse.urlunparse((parsed.scheme, parsed.netloc, "", "", "", ""))


def open_new_tab(cdp_list_url: str, url: str) -> dict[str, Any]:
    endpoint = f"{cdp_base_url(cdp_list_url)}/json/new?{urllib.parse.quote(url, safe='')}"
    request = urllib.request.Request(endpoint, method="PUT")
    opener = urllib.request.build_opener(urllib.request.ProxyHandler({}))
    with opener.open(request, timeout=10.0) as response:
        return json.loads(response.read().decode("utf-8"))


def prepare_chrome_user_data_dir(args: argparse.Namespace) -> str:
    profile = pathlib.Path(args.chrome_user_data_dir).expanduser()
    profile.mkdir(parents=True, exist_ok=True)
    for name in ("SingletonCookie", "SingletonLock", "SingletonSocket"):
        path = profile / name
        try:
            path.unlink()
        except FileNotFoundError:
            pass
    return str(profile)


def chrome_environment(headless: bool) -> dict[str, str] | None:
    if headless or os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"):
        return None
    env = os.environ.copy()
    uid = os.getuid()
    runtime = pathlib.Path(f"/run/user/{uid}")
    if runtime.exists():
        env.setdefault("XDG_RUNTIME_DIR", str(runtime))
        if (runtime / "wayland-0").exists():
            env.setdefault("WAYLAND_DISPLAY", "wayland-0")
            env.setdefault("XDG_SESSION_TYPE", "wayland")
        xauth_files = sorted(runtime.glob("xauth_*"))
        if xauth_files:
            env.setdefault("XAUTHORITY", str(xauth_files[0]))
    env.setdefault("DISPLAY", ":1")
    env.setdefault("DBUS_SESSION_BUS_ADDRESS", f"unix:path=/run/user/{uid}/bus")
    return env


def stop_chrome() -> None:
    global CHROME_PROCESS
    if CHROME_PROCESS is None:
        return
    if CHROME_PROCESS.poll() is None:
        CHROME_PROCESS.terminate()
        try:
            CHROME_PROCESS.wait(timeout=5)
        except subprocess.TimeoutExpired:
            CHROME_PROCESS.kill()
            CHROME_PROCESS.wait(timeout=5)
    CHROME_PROCESS = None


def launch_chrome(args: argparse.Namespace, *, headless: bool | None = None) -> subprocess.Popen[Any]:
    global CHROME_PROCESS
    if headless is None:
        headless = args.headless
    user_data_dir = prepare_chrome_user_data_dir(args)
    cmd = [
        args.chrome_bin,
        f"--remote-debugging-port={args.cdp_port}",
        "--remote-debugging-address=127.0.0.1",
        f"--user-data-dir={user_data_dir}",
        f"--profile-directory={args.profile_directory}",
        "--no-first-run",
    ]
    if headless:
        cmd.extend(
            [
                "--headless=new",
                "--disable-gpu",
                "--disable-dev-shm-usage",
                f"--window-size={args.window_size}",
            ]
        )
        log("launching headless Chrome with jupyter-tool profile")
    else:
        cmd.append("--new-window")
        log("launching visible Chrome with jupyter-tool profile")
    cmd.append(args.hub_url)
    CHROME_PROCESS = subprocess.Popen(cmd, env=chrome_environment(headless))
    return CHROME_PROCESS


def ensure_cdp(args: argparse.Namespace, *, headless: bool | None = None) -> None:
    global CHROME_PROCESS
    try:
        fetch_targets(args.cdp_list_url)
        return
    except Exception as exc:
        if args.no_launch:
            raise JupyterdError(f"Chrome DevTools is not reachable: {exc}") from exc

    if CHROME_PROCESS is None or CHROME_PROCESS.poll() is not None:
        launch_chrome(args, headless=headless)
    else:
        log("waiting for existing Chrome process to expose DevTools")
    deadline = time.monotonic() + args.chrome_start_timeout
    last_error: Exception | None = None
    while time.monotonic() < deadline:
        try:
            fetch_targets(args.cdp_list_url)
            return
        except Exception as exc:
            last_error = exc
            time.sleep(0.5)
    stop_chrome()
    raise JupyterdError(
        "Chrome DevTools did not become reachable. If Chrome was already using this profile, "
        "close it and start it with --remote-debugging-port, or run jupyterd after launching "
        f"Chrome manually. Last error: {last_error}"
    )


def auth_cache_path(args: argparse.Namespace) -> pathlib.Path:
    return pathlib.Path(args.auth_cache).expanduser()


def load_cached_auth(args: argparse.Namespace) -> Any | None:
    path = auth_cache_path(args)
    if not path.exists():
        return None
    try:
        auth = JUPYTER_DIRECT.CookieAuth.from_cache(path)
    except Exception as exc:
        log(f"ignored unreadable auth cache: {exc}")
        return None
    if not auth.valid(margin=args.auth_refresh_margin):
        return None
    return auth


def extract_auth_from_chrome(args: argparse.Namespace, *, headless: bool | None = None) -> Any:
    ensure_cdp(args, headless=headless)
    try:
        auth = JUPYTER_DIRECT.extract_cookies_from_cdp(args.cdp_list_url, debug=args.debug)
    except Exception:
        open_new_tab(args.cdp_list_url, args.hub_url)
        time.sleep(args.hub_load_delay)
        auth = JUPYTER_DIRECT.extract_cookies_from_cdp(args.cdp_list_url, debug=args.debug)
    auth.save(auth_cache_path(args))
    summary = auth.redacted_summary()
    log(f"cached GitCode auth from Chrome profile: {len(summary.get('names', []))} cookie names")
    return auth


def get_direct_auth(
    args: argparse.Namespace,
    *,
    force_extract: bool = False,
    allow_chrome: bool = True,
    headless: bool | None = None,
) -> Any:
    if not force_extract:
        cached = load_cached_auth(args)
        if cached is not None:
            return cached
    if not allow_chrome:
        raise JupyterdError("GitCode auth cache is missing or expired")
    return extract_auth_from_chrome(args, headless=headless)


def direct_probe_output(status: dict[str, Any], notebook: Any) -> str:
    pieces = [f"notebook_id={notebook.notebook_id}"]
    for key in ("connections", "kernels", "started", "last_activity"):
        if key in status:
            pieces.append(f"{key}={status[key]}")
    return "\n".join(pieces)


def previous_notebook_from_state(args: argparse.Namespace) -> Any | None:
    if not args.state_file:
        return None
    path = pathlib.Path(args.state_file).expanduser()
    if not path.exists():
        return None
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
        href = str(data.get("href") or "")
        if "aihub-run.gitcode.com" not in href:
            return None
        return JUPYTER_DIRECT.notebook_from_lab_url(
            href,
            target_url=str(data.get("target_url") or ""),
            raw={
                "state_file": str(path),
                "state_time": data.get("time"),
                "status": data.get("status") if isinstance(data.get("status"), dict) else {},
                "notebook_id": data.get("notebook_id"),
            },
        )
    except Exception as exc:
        log(f"ignored unusable notebook state: {exc}")
        return None


def direct_probe_context(client: Any, notebook: Any, args: argparse.Namespace) -> SimpleNamespace:
    status = JUPYTER_DIRECT.probe_notebook(client, notebook, timeout=args.probe_timeout)
    previous_started = str((notebook.raw.get("status") or {}).get("started") or "")
    current_started = str(status.get("started") or "")
    if previous_started and current_started and previous_started != current_started:
        log(
            "notebook backend restarted; remote temporary files may have been reset: "
            f"{notebook.base_url} previous_started={previous_started} current_started={current_started}"
        )
    probe = {
        "ok": True,
        "href": notebook.lab_url,
        "target_url": notebook.target_url,
        "notebook_id": notebook.notebook_id,
        "base_url": notebook.base_url,
        "status": status,
        "output": direct_probe_output(status, notebook),
    }
    return SimpleNamespace(client=client, notebook=notebook, status=status, probe=probe)


def direct_context(
    args: argparse.Namespace,
    *,
    timeout: float,
    force_auth_extract: bool = False,
    allow_chrome: bool = True,
    headless: bool | None = None,
    skip_previous: bool = False,
) -> SimpleNamespace:
    deadline = time.monotonic() + timeout
    last_error: Exception | None = None
    force_extract_next = force_auth_extract
    previous_dead = skip_previous
    while True:
        try:
            auth = get_direct_auth(
                args,
                force_extract=force_extract_next,
                allow_chrome=allow_chrome,
                headless=headless,
            )
            client = JUPYTER_DIRECT.HttpClient(auth, cache_path=auth_cache_path(args))
            previous = previous_notebook_from_state(args)
            if previous is not None and not previous_dead:
                try:
                    context = direct_probe_context(client, previous, args)
                    context.auth = auth
                    log(f"reusing previous notebook: {previous.base_url}")
                    return context
                except JUPYTER_DIRECT.AuthError as exc:
                    last_error = exc
                    if allow_chrome and not force_extract_next:
                        raise
                    previous_dead = True
                    log(f"previous notebook is not reusable after auth check: {exc}")
                except Exception as exc:
                    last_error = exc
                    previous_dead = True
                    log(f"previous notebook is not reusable: {exc}")

            notebook = JUPYTER_DIRECT.insert_notebook(client, args)
            if notebook.provisioning_status and notebook.provisioning_status != "READY":
                raise JupyterdError(
                    "notebook is not ready: "
                    f"status={notebook.provisioning_status} queue={notebook.raw.get('queue_ahead_count')}"
                )
            context = direct_probe_context(client, notebook, args)
            context.auth = auth
            return context
        except JUPYTER_DIRECT.AuthError as exc:
            last_error = exc
            if allow_chrome and not force_extract_next:
                force_extract_next = True
                continue
        except Exception as exc:
            last_error = exc

        if time.monotonic() >= deadline:
            raise JupyterdError(f"direct notebook probe failed: {last_error}") from last_error
        time.sleep(args.create_probe_interval)


