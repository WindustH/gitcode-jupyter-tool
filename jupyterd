def wait_for_marker(
    session: Any,
    output: collections.deque[str],
    marker: str,
    timeout: float,
) -> tuple[int, str]:
    collected = ""
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        while output:
            collected += output.popleft()
            match = re.search(re.escape(marker) + r"([0-9]+)", collected)
            if match:
                return int(match.group(1)), JUPYTER_SH.strip_terminal_noise(collected[: match.start()])
            if len(collected) > 8192:
                collected = collected[-4096:]
        session.cdp.pump(0.1)
    raise JupyterdError(f"notebook probe timed out after {timeout:.1f}s")


def probe_notebook(args: argparse.Namespace) -> dict[str, Any]:
    session = JUPYTER_SH.connect_browser(
        sh_args(args, target=args.notebook_target_contains, page=args.notebook_page_contains)
    )
    output: collections.deque[str] = collections.deque()
    marker = f"__JUPYTERD_PROBE_{secrets.token_hex(8)}__:"
    terminal = JUPYTER_SH.BrowserTerminal(session, output.append, rows=24, cols=120)
    try:
        terminal.start()
        session.cdp.pump_for(0.5)
        output.clear()
        terminal.send("stty -echo 2>/dev/null || true\nexport PS1='' PS2=''\n")
        session.cdp.pump_for(0.2)
        output.clear()
        terminal.send(
            "\n".join(
                [
                    "(",
                    "pwd",
                    "python3 - <<'PY'",
                    "import sys",
                    "print('python=' + sys.version.split()[0])",
                    "PY",
                    ")",
                    "__jupyterd_status=$?",
                    f"printf '{marker}%s\\n' \"$__jupyterd_status\"",
                    "",
                ]
            )
        )
        status, text = wait_for_marker(session, output, marker, args.probe_timeout)
        return {
            "ok": status == 0,
            "status": status,
            "href": session.href,
            "target_url": session.target_url or session.href,
            "output": text.strip(),
        }
    finally:
        terminal.close()
        session.cdp.close()


def find_page_target(args: argparse.Namespace, contains: str) -> dict[str, Any] | None:
    for target in fetch_targets(args.cdp_list_url):
        if target.get("type") == "page" and contains in target.get("url", ""):
            return target
    return None


def select_context(cdp: Any, contains: str, timeout: float) -> tuple[int, str]:
    cdp.call("Page.enable")
    cdp.call("Runtime.enable")
    cdp.pump_for(0.5)
    seen: dict[int, str] = {}
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        for context_id in list(cdp.contexts):
            if context_id in seen:
                continue
            try:
                href = str(cdp.evaluate(context_id, "location.href"))
            except Exception:
                continue
            seen[context_id] = href
            if contains in href:
                return context_id, href
        cdp.pump(0.2)
    details = "\n".join(f"- {cid}: {href}" for cid, href in seen.items()) or "(no contexts)"
    raise JupyterdError(f"could not find page context containing {contains!r}:\n{details}")


CLICK_EXPERIENCE_JS = r"""
(async function(index) {
  const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
  const textOf = (el) => (el.innerText || el.textContent || el.getAttribute("aria-label") || "").trim();
  const isVisible = (el) => {
    const style = getComputedStyle(el);
    const box = el.getBoundingClientRect();
    return style.display !== "none" && style.visibility !== "hidden" && box.width > 0 && box.height > 0;
  };
  const collectCandidates = () => {
    const candidates = [];
    const seen = new Set();
    const addCandidate = (el, score) => {
    const text = textOf(el);
    const href = el.href || el.getAttribute("href") || "";
    if (seen.has(el) || !isVisible(el)) return;
    seen.add(el);
    candidates.push({ el, score, text, href });
    };

    for (const el of document.querySelectorAll("a[href]")) {
      const text = textOf(el);
      const href = el.href || el.getAttribute("href") || "";
      if (href.includes("notebookcann") && text.includes("在线体验")) addCandidate(el, 0);
      else if (href.includes("notebookcann")) addCandidate(el, 1);
      else if (text === "在线体验" || text.includes("在线体验")) addCandidate(el, 3);
    }
    if (!candidates.length) {
      for (const el of document.querySelectorAll("button,[role='button']")) {
        const text = textOf(el);
        if (!text.includes("在线体验") && !text.includes("CANNLab")) continue;
        addCandidate(el, text.includes("CANNLab") ? 4 : 5);
      }
    }
    candidates.sort((a, b) => a.score - b.score);
    return candidates;
  };

  let candidates = [];
  for (let attempt = 0; attempt < 40; attempt++) {
    candidates = collectCandidates();
    if (candidates.length) break;
    await sleep(500);
  }

  if (!candidates.length) {
    const samples = Array.from(document.querySelectorAll("a,button,[role='button']"))
      .slice(0, 40)
      .map((el) => ({
        text: textOf(el).slice(0, 80),
        href: el.href || el.getAttribute("href") || "",
        tag: el.tagName,
      }));
    return {
      ok: false,
      reason: "no visible online experience entry",
      title: document.title,
      url: location.href,
      samples,
    };
  }

  const chosen = candidates[Math.min(index, candidates.length - 1)];
  chosen.el.scrollIntoView({ block: "center", inline: "center" });
  await sleep(200);
  if (chosen.href) {
    location.href = chosen.href;
  } else {
    chosen.el.click();
  }
  return {
    ok: true,
    count: candidates.length,
    score: chosen.score,
    text: chosen.text,
    href: chosen.href,
    url: location.href,
  };
})(%d)
"""


def click_online_experience(args: argparse.Namespace) -> dict[str, Any]:
    target = find_page_target(args, args.hub_target_contains)
    if target is None:
        log(f"opening hub: {args.hub_url}")
        target = open_new_tab(args.cdp_list_url, args.hub_url)
        time.sleep(args.hub_load_delay)

    cdp = JUPYTER_SH.CdpClient(target["webSocketDebuggerUrl"], debug=args.debug)
    try:
        context_id, href = select_context(cdp, args.hub_context_contains, args.context_wait)
        log(f"hub page ready: {href}")
        result = cdp.evaluate(
            context_id,
            CLICK_EXPERIENCE_JS % args.experience_index,
            await_promise=True,
            timeout_ms=20000,
        )
        if not result or not result.get("ok"):
            raise JupyterdError(f"could not click 在线体验: {json.dumps(result, ensure_ascii=False)}")
        log(f"clicked 在线体验 entry #{args.experience_index}: {result.get('text', '')}")
        return result
    finally:
        cdp.close()


def write_state(args: argparse.Namespace, data: dict[str, Any]) -> None:
    if not args.state_file:
        return
    path = pathlib.Path(args.state_file).expanduser()
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def record_ok_state(args: argparse.Namespace, probe: dict[str, Any]) -> None:
    status = probe.get("status") if isinstance(probe.get("status"), dict) else {}
    write_state(
        args,
        {
            "ok": True,
            "href": probe["href"],
            "target_url": probe.get("target_url") or probe["href"],
            "notebook_id": probe.get("notebook_id"),
            "base_url": probe.get("base_url"),
            "status": status,
            "remote_started": status.get("started"),
            "remote_last_activity": status.get("last_activity"),
            "target_url_contains": args.notebook_target_contains,
            "page_url_contains": args.notebook_page_contains,
            "profile": str(pathlib.Path(args.chrome_user_data_dir).expanduser()),
            "probe": probe["output"],
            "time": time.time(),
        },
    )


def wait_for_notebook_after_click(args: argparse.Namespace, timeout: float) -> bool:
    deadline = time.monotonic() + timeout
    last_error: Exception | None = None
    while time.monotonic() < deadline:
        time.sleep(args.create_probe_interval)
        try:
            probe = probe_notebook(args)
            if probe["ok"]:
                log(f"notebook created: {probe['href']} | {probe['output'].replace(chr(10), ' ; ')}")
                record_ok_state(args, probe)
                return True
        except Exception as exc:
            last_error = exc
    raise JupyterdError(f"notebook was not usable after creation timeout: {last_error}")


def open_login_window_and_wait(args: argparse.Namespace, reason: Exception | str) -> bool:
    if args.no_login_window:
        raise JupyterdError(f"notebook is unavailable and login window is disabled: {reason}")

    log(f"opening visible login window because notebook is unavailable: {reason}")
    stop_chrome()
    ensure_cdp(args, headless=False)
    log("GitCode login may be required. Complete login in the visible Chrome window; jupyterd will keep polling.")

    deadline = time.monotonic() + args.login_timeout
    last_error: Exception | None = None
    while time.monotonic() < deadline:
        try:
            context = direct_context(
                args,
                timeout=max(1.0, args.login_probe_interval),
                force_auth_extract=True,
                allow_chrome=True,
                headless=False,
            )
            probe = context.probe
            log(f"notebook ok after login: {probe['href']} | {probe['output'].replace(chr(10), ' ; ')}")
            record_ok_state(args, probe)
            return True
        except Exception as exc:
            last_error = exc

        time.sleep(args.login_probe_interval)

    raise JupyterdError(f"visible login window was opened, but notebook is still unavailable: {last_error}")


def maintain_once(args: argparse.Namespace) -> bool:
    try:
        context = direct_context(
            args,
            timeout=args.direct_timeout,
            force_auth_extract=False,
            allow_chrome=not args.no_launch,
            headless=args.headless,
        )
        probe = context.probe
        log(f"notebook ok: {probe['href']} | {probe['output'].replace(chr(10), ' ; ')}")
        record_ok_state(args, probe)
        return True
    except Exception as exc:
        log(f"notebook not ready: {exc}")

    if args.status_only:
        write_state(args, {"ok": False, "reason": "status_only", "time": time.time()})
        return False

    write_state(args, {"ok": False, "reason": "direct_probe_failed", "time": time.time()})
    if not args.no_login_window and not args.no_launch:
        return open_login_window_and_wait(args, "direct probe failed")
    raise JupyterdError("direct notebook probe failed and browser launch is disabled")


def terminal_rows_cols(rows: int | None, cols: int | None) -> tuple[int, int]:
    return rows or 24, cols or 120


def wait_command_marker(
    session: Any,
    output: collections.deque[str],
    marker: str,
    timeout: float,
    *,
    raw: bool,
) -> tuple[int, str]:
    collected = ""
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        while output:
            collected += output.popleft()
            match = re.search(re.escape(marker) + r"([0-9]+)", collected)
            if match:
                text = collected[: match.start()]
                return int(match.group(1)), text if raw else JUPYTER_SH.strip_terminal_noise(text)
            if len(collected) > 1024 * 1024 * 16:
                collected = collected[-1024 * 1024 * 8 :]
        session.cdp.pump(0.1)
    return 124, collected if raw else JUPYTER_SH.strip_terminal_noise(collected)


def wait_api_command_marker(
    terminal: Any,
    output: collections.deque[str],
    marker: str,
    timeout: float,
    *,
    raw: bool,
) -> tuple[int, str]:
    collected = ""
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        while output:
            collected += output.popleft()
            match = re.search(re.escape(marker) + r"([0-9]+)", collected)
            if match:
                text = collected[: match.start()]
                return int(match.group(1)), text if raw else JUPYTER_SH.strip_terminal_noise(text)
            if len(collected) > 1024 * 1024 * 16:
                collected = collected[-1024 * 1024 * 8 :]
        chunk = terminal.read_once(0.1)
        if chunk:
            output.append(chunk)
        if getattr(terminal, "closed", False):
            while output:
                collected += output.popleft()
            raise JupyterdError("remote terminal closed before command completed")
    return 124, collected if raw else JUPYTER_SH.strip_terminal_noise(collected)


def drain_api_terminal(terminal: Any, output: collections.deque[str], seconds: float) -> None:
    deadline = time.monotonic() + seconds
    while time.monotonic() < deadline:
        chunk = terminal.read_once(max(0.01, min(0.1, deadline - time.monotonic())))
        if chunk:
            output.append(chunk)


class AsyncJobManager:
    def __init__(self, *, max_workers: int, retention: float) -> None:
        self.retention = retention
        self.executor = concurrent.futures.ThreadPoolExecutor(
            max_workers=max_workers,
            thread_name_prefix="jupyterd-job",
        )
        self.lock = threading.Lock()
        self.jobs: dict[str, dict[str, Any]] = {}

    def submit(self, name: str, func: Any, *args: Any, **kwargs: Any) -> dict[str, Any]:
        job_id = secrets.token_hex(12)
        now = time.time()
        with self.lock:
            self._prune_locked(now)
            self.jobs[job_id] = {
                "id": job_id,
                "name": name,
                "status": "queued",
                "submitted": now,
            }
        self.executor.submit(self._run, job_id, func, args, kwargs)
        return self.get(job_id)

    def _run(self, job_id: str, func: Any, args: tuple[Any, ...], kwargs: dict[str, Any]) -> None:
        with self.lock:
            job = self.jobs.get(job_id)
            if job is not None:
                job["status"] = "running"
                job["started"] = time.time()
        try:
            result = func(*args, **kwargs)
        except Exception as exc:
            with self.lock:
                job = self.jobs.get(job_id)
                if job is not None:
                    job["status"] = "failed"
                    job["ok"] = False
                    job["error"] = str(exc)
                    job["finished"] = time.time()
            return
        with self.lock:
            job = self.jobs.get(job_id)
            if job is not None:
                job["status"] = "succeeded"
                job["ok"] = True
                job["result"] = result
                job["finished"] = time.time()

    def get(self, job_id: str) -> dict[str, Any]:
        with self.lock:
            job = self.jobs.get(job_id)
            if job is None:
                raise JupyterdError(f"unknown job id: {job_id}")
            return dict(job)

    def _prune_locked(self, now: float) -> None:
        if self.retention <= 0:
            return
        expired: list[str] = []
        for job_id, job in self.jobs.items():
            if job.get("status") in {"queued", "running"}:
                continue
            finished = float(job.get("finished") or job.get("submitted") or now)
            if now - finished > self.retention:
                expired.append(job_id)
        for job_id in expired:
            self.jobs.pop(job_id, None)

    def stats(self) -> dict[str, int]:
        counts: dict[str, int] = {}
        with self.lock:
            for job in self.jobs.values():
                status = str(job.get("status", "unknown"))
                counts[status] = counts.get(status, 0) + 1
        return counts

    def shutdown(self) -> None:
        self.executor.shutdown(wait=False, cancel_futures=True)


class LiveTerminal:
    def __init__(self, service: "JupyterDaemonService", rows: int, cols: int) -> None:
        self.service = service
        self.id = secrets.token_hex(12)
        self.output: collections.deque[str] = collections.deque()
        self.condition = threading.Condition()
        self.io_lock = threading.RLock()
        self.closed = False
        last_error: Exception | None = None
        for attempt in range(2):
            self.context = service.direct_context(skip_previous=attempt > 0)
            self.href = self.context.notebook.lab_url
            self.terminal = JUPYTER_DIRECT.ApiTerminal(
                self.context.client,
                self.context.notebook,
                self._on_output,
                rows=rows,
                cols=cols,
            )
            try:
                with self.io_lock:
                    self.terminal.start()
                break
            except Exception as exc:
                last_error = exc
                self.terminal.close()
                if attempt == 0:
                    log(f"interactive terminal failed on current notebook; replacing notebook: {exc}")
                    continue
                raise
        if last_error is not None and getattr(self, "terminal", None) is None:
            raise last_error
        self.thread = threading.Thread(target=self._pump_loop, name=f"jupyterd-terminal-{self.id}", daemon=True)
        self.thread.start()

    def _on_output(self, text: str) -> None:
        if JUPYTER_SH.TERMINAL_CLOSED_MARK in text:
            text = text.replace(JUPYTER_SH.TERMINAL_CLOSED_MARK, "")
            self.closed = True
        with self.condition:
            if text:
                self.output.append(text)
            self.condition.notify_all()

    def _pump_loop(self) -> None:
        while not self.closed:
            try:
                with self.io_lock:
                    text = self.terminal.read_once(0.02)
                if text:
                    self._on_output(text)
            except Exception as exc:
                self._on_output(f"\n[jupyterd terminal pump failed: {exc}]\n")
                self.closed = True
                break

    def input(self, data: str) -> None:
        with self.io_lock:
            self.terminal.send(data)

    def resize(self, rows: int, cols: int) -> None:
        with self.io_lock:
            self.terminal.set_size(rows, cols)

    def read(self, timeout: float) -> str:
        deadline = time.monotonic() + timeout
        chunks: list[str] = []
        with self.condition:
            while not self.output and not self.closed and time.monotonic() < deadline:
                self.condition.wait(max(0.0, deadline - time.monotonic()))
            while self.output:
                chunks.append(self.output.popleft())
        return "".join(chunks)

    def prepare_interactive_prompt(self) -> str:
        self.read(0.2)
        self.input("stty -echo 2>/dev/null || true\n")
        self.read(0.2)

        marker = f"__JUPYTERD_PROMPT_READY_{secrets.token_hex(8)}__"
        prelude = "\n".join(
            [
                "bind 'set enable-bracketed-paste off' 2>/dev/null || true",
                "alias ll='ls -l --color=auto'",
                "export PROMPT_COMMAND=",
                f"export PS1={shlex.quote(INTERACTIVE_PS1)}",
                f"printf '\\033[2K\\r%s\\n' {shlex.quote(marker)}",
                "",
            ]
        )
        self.input(prelude)

        collected = ""
        deadline = time.monotonic() + 3.0
        while time.monotonic() < deadline and marker not in collected:
            collected += self.read(0.05)
        settle_deadline = time.monotonic() + 0.25
        while time.monotonic() < settle_deadline:
            collected += self.read(0.05)

        marker_index = collected.find(marker)
        if marker_index < 0:
            return ""

        self.input("stty echo 2>/dev/null || true\n")
        return self.read(0.5).lstrip("\r\n")

    def close(self) -> None:
        self.closed = True
        with self.condition:
            self.condition.notify_all()
        with self.io_lock:
            self.terminal.close()


class JupyterDaemonService:
    def __init__(self, args: argparse.Namespace) -> None:
        self.args = args
        self.jobs = AsyncJobManager(max_workers=args.worker_threads, retention=args.job_retention)
        self.ensure_lock = threading.Lock()
        self.terminals: dict[str, LiveTerminal] = {}
        self.terminals_lock = threading.Lock()

    def close(self) -> None:
        self.jobs.shutdown()
        with self.terminals_lock:
            terminals = list(self.terminals)
        for terminal_id in terminals:
            self.close_terminal(terminal_id)

    def submit_job(self, name: str, func: Any, *args: Any, **kwargs: Any) -> dict[str, Any]:
        job = self.jobs.submit(name, func, *args, **kwargs)
        return {"ok": True, "job_id": job["id"], "job": job}

    def get_job(self, job_id: str) -> dict[str, Any]:
        return {"ok": True, "job": self.jobs.get(job_id)}

    def ensure(self) -> bool:
        self.direct_context()
        return True

    def direct_context(self, *, skip_previous: bool = False) -> Any:
        with self.ensure_lock:
            context = direct_context(
                self.args,
                timeout=self.args.create_timeout,
                force_auth_extract=False,
                allow_chrome=not self.args.no_launch,
                headless=self.args.headless,
                skip_previous=skip_previous,
            )
            record_ok_state(self.args, context.probe)
            return context

    def connect_notebook(self) -> Any:
        return JUPYTER_SH.connect_browser(
            sh_args(
                self.args,
                target=self.args.notebook_target_contains,
                page=self.args.notebook_page_contains,
            )
        )

    def run_command(
        self,
        command: str,
        *,
        timeout: float,
        rows: int | None = None,
        cols: int | None = None,
        raw: bool = False,
        no_prelude: bool = False,
        ensure: bool = True,
    ) -> dict[str, Any]:
        last_error: Exception | None = None
        for attempt in range(2):
            context = self.direct_context(skip_previous=attempt > 0) if ensure else direct_context(
                self.args,
                timeout=self.args.direct_timeout,
                force_auth_extract=False,
                allow_chrome=False,
                skip_previous=attempt > 0,
            )
            output: collections.deque[str] = collections.deque()
            marker = f"__JUPYTERD_RUN_{secrets.token_hex(8)}__:"
            row_count, col_count = terminal_rows_cols(rows, cols)
            terminal = JUPYTER_DIRECT.ApiTerminal(
                context.client,
                context.notebook,
                output.append,
                rows=row_count,
                cols=col_count,
            )
            try:
                terminal.start()
                drain_api_terminal(terminal, output, 0.5)
                output.clear()
                if not no_prelude:
                    terminal.send("stty -echo 2>/dev/null || true\nexport PS1='' PS2=''\n")
                    drain_api_terminal(terminal, output, 0.2)
                    output.clear()
                wrapped = "\n".join(
                    [
                        "(",
                        command,
                        ")",
                        "__jupyterd_run_status=$?",
                        f"printf '{marker}%s\\n' \"$__jupyterd_run_status\"",
                        "",
                    ]
                )
                terminal.send(wrapped)
                status, text = wait_api_command_marker(terminal, output, marker, timeout, raw=raw)
                return {"ok": status == 0, "exit_code": status, "stdout": text, "href": context.notebook.lab_url}
            except Exception as exc:
                last_error = exc
                if attempt == 0:
                    log(f"remote command failed on current notebook; replacing notebook: {exc}")
                    continue
                raise
            finally:
                terminal.close()
        raise JupyterdError(f"remote command failed after notebook replacement: {last_error}")

    def upload(
        self,
        *,
        destination: str,
        payload_b64: str,
        mode: int,
        is_archive: bool,
        timeout: float,
        chunk_size: int,
    ) -> dict[str, Any]:
        marker = f"__JUPYTERD_UPLOAD_{secrets.token_hex(8)}__:"
        heredoc = f"__JUPYTERD_UPLOAD_PAYLOAD_{secrets.token_hex(8)}__"
        destination_arg = shlex.quote(destination)
        archive_flag = "1" if is_archive else "0"
        remote_decode = r"""python3 - "$tmp_b64" %s %s %o <<'__JUPYTERD_UPLOAD_PY__'
import base64
import os
import pathlib
import sys
import tarfile
import tempfile

payload_path = pathlib.Path(sys.argv[1])
destination = pathlib.Path(os.path.expanduser(sys.argv[2]))
is_archive = sys.argv[3] == "1"
mode = int(sys.argv[4], 8)
data = base64.b64decode(payload_path.read_bytes())

if is_archive:
    destination.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(prefix="jupyterd-upload-", suffix=".tar.gz", delete=False) as handle:
        handle.write(data)
        archive_name = handle.name
    try:
        with tarfile.open(archive_name, "r:gz") as archive:
            archive.extractall(destination)
    finally:
        try:
            os.unlink(archive_name)
        except FileNotFoundError:
            pass
else:
    destination.parent.mkdir(parents=True, exist_ok=True)
    destination.write_bytes(data)
    os.chmod(destination, mode)
__JUPYTERD_UPLOAD_PY__
""" % (
            destination_arg,
            archive_flag,
            mode,
        )
        last_error: Exception | None = None
        for attempt in range(2):
            context = self.direct_context(skip_previous=attempt > 0)
            output: collections.deque[str] = collections.deque()
            terminal = JUPYTER_DIRECT.ApiTerminal(
                context.client,
                context.notebook,
                output.append,
                rows=24,
                cols=120,
            )
            try:
                terminal.start()
                drain_api_terminal(terminal, output, 0.5)
                output.clear()
                terminal.send("stty -echo 2>/dev/null || true\nexport PS1='' PS2=''\n")
                drain_api_terminal(terminal, output, 0.2)
                output.clear()
                terminal.send(
                    "\n".join(
                        [
                            "set +e",
                            "tmp_b64=$(mktemp /tmp/jupyterd-upload.XXXXXX.b64)",
                            "cleanup_jupyterd_upload() { rm -f \"$tmp_b64\"; }",
                            "trap cleanup_jupyterd_upload EXIT",
                            f"cat > \"$tmp_b64\" <<'{heredoc}'",
                            "",
                        ]
                    )
                )
                for index in range(0, len(payload_b64), chunk_size):
                    terminal.send(payload_b64[index : index + chunk_size])
                if not payload_b64.endswith("\n"):
                    terminal.send("\n")
                terminal.send(
                    "\n".join(
                        [
                            heredoc,
                            remote_decode,
                            "__jupyterd_upload_status=$?",
                            f"printf '{marker}%s\\n' \"$__jupyterd_upload_status\"",
                            "",
                        ]
                    )
                )
                status, text = wait_api_command_marker(terminal, output, marker, timeout, raw=False)
                if status != 0:
                    return {"ok": False, "exit_code": status, "stdout": text, "href": context.notebook.lab_url}
                return {"ok": True, "exit_code": 0, "stdout": text, "href": context.notebook.lab_url}
            except Exception as exc:
                last_error = exc
                if attempt == 0:
                    log(f"upload failed on current notebook; replacing notebook: {exc}")
                    continue
                raise
            finally:
                terminal.close()
        raise JupyterdError(f"upload failed after notebook replacement: {last_error}")

    def download(self, *, source: str, recursive: bool, timeout: float) -> dict[str, Any]:
        source_arg = shlex.quote(source)
        recursive_arg = "1" if recursive else "0"
        command = r"""python3 - %s %s <<'__JUPYTERD_DOWNLOAD_PY__'
import base64
import io
import os
import pathlib
import sys
import tarfile

source = pathlib.Path(os.path.expanduser(sys.argv[1]))
recursive = sys.argv[2] == "1"
if source.is_dir():
    if not recursive:
        raise SystemExit(f"{source} is a directory; use -r to copy directories")
    buffer = io.BytesIO()
    with tarfile.open(fileobj=buffer, mode="w:gz") as archive:
        for child in source.iterdir():
            archive.add(child, arcname=child.name, recursive=True)
    payload = buffer.getvalue()
else:
    payload = source.read_bytes()
print("%s")
sys.stdout.write(base64.encodebytes(payload).decode("ascii"))
print("%s")
__JUPYTERD_DOWNLOAD_PY__
""" % (
            source_arg,
            recursive_arg,
            DOWNLOAD_BEGIN_MARK,
            DOWNLOAD_END_MARK,
        )
        result = self.run_command(command, timeout=timeout, raw=False)
        if not result.get("ok"):
            return result
        stdout = result.get("stdout", "")
        begin = stdout.find(DOWNLOAD_BEGIN_MARK)
        end = stdout.find(DOWNLOAD_END_MARK)
        if begin < 0 or end < 0 or end < begin:
            return {
                "ok": False,
                "exit_code": 1,
                "stdout": stdout,
                "error": "remote download did not return a payload",
                "href": result.get("href"),
            }
        payload = "".join(stdout[begin + len(DOWNLOAD_BEGIN_MARK) : end].split())
        return {"ok": True, "exit_code": 0, "content_b64": payload, "href": result.get("href")}

    def start_terminal(self, *, rows: int, cols: int) -> dict[str, Any]:
        terminal = self.open_terminal(rows=rows, cols=cols)
        initial_output = terminal.prepare_interactive_prompt()
        with self.terminals_lock:
            self.terminals[terminal.id] = terminal
        return {"ok": True, "id": terminal.id, "href": terminal.href, "initial_output": initial_output}

    def open_terminal(self, *, rows: int, cols: int) -> LiveTerminal:
        try:
            return LiveTerminal(self, rows, cols)
        except Exception:
            self.ensure()
            return LiveTerminal(self, rows, cols)

    def get_terminal(self, terminal_id: str) -> LiveTerminal:
        with self.terminals_lock:
            terminal = self.terminals.get(terminal_id)
        if terminal is None:
            raise JupyterdError(f"unknown terminal id: {terminal_id}")
        return terminal

    def close_terminal(self, terminal_id: str) -> None:
        with self.terminals_lock:
            terminal = self.terminals.pop(terminal_id, None)
        if terminal is not None:
            terminal.close()


class JupyterdRequestHandler(http.server.BaseHTTPRequestHandler):
    service: JupyterDaemonService

    def log_message(self, format: str, *args: Any) -> None:
        log(f"{self.client_address[0]} {format % args}")

    def _read_json(self) -> dict[str, Any]:
        length = int(self.headers.get("Content-Length", "0"))
        raw = self.rfile.read(length) if length else b"{}"
        if not raw:
            return {}
        return json.loads(raw.decode("utf-8"))

    def _send_json(self, status: int, payload: dict[str, Any]) -> None:
        data = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self) -> None:
        if self.path in {"/", "/v1/health"}:
            self._send_json(
                200,
                {
                    "ok": True,
                    "service": "jupyterd",
                    "pid": os.getpid(),
                    "jobs": self.service.jobs.stats(),
                    "stream_url": f"tcp://{self.service.args.stream_host}:{self.service.args.stream_port}",
                },
            )
            return
        self._send_json(404, {"ok": False, "error": f"unknown endpoint: {self.path}"})

    def do_POST(self) -> None:
        try:
            request = self._read_json()
            response = self._dispatch(request)
            self._send_json(200, response)
        except Exception as exc:
            self._send_json(200, {"ok": False, "error": str(exc)})

    def _dispatch(self, request: dict[str, Any]) -> dict[str, Any]:
        async_job = bool(request.get("async", False))
        if self.path == "/v1/shutdown":
            threading.Thread(target=self.server.shutdown, name="jupyterd-shutdown", daemon=True).start()
            return {"ok": True, "pid": os.getpid()}
        if self.path == "/v1/job":
            return self.service.get_job(str(request["id"]))
        if self.path == "/v1/ensure":
            if async_job:
                return self.service.submit_job("ensure", self.service.ensure)
            ok = self.service.ensure()
            return {"ok": ok}
        if self.path == "/v1/run":
            kwargs = {
                "timeout": float(request.get("timeout", 180.0)),
                "rows": request.get("rows"),
                "cols": request.get("cols"),
                "raw": bool(request.get("raw", False)),
                "no_prelude": bool(request.get("no_prelude", False)),
                "ensure": bool(request.get("ensure", True)),
            }
            command = str(request.get("command", ""))
            if async_job:
                return self.service.submit_job("run", self.service.run_command, command, **kwargs)
            return self.service.run_command(command, **kwargs)
        if self.path == "/v1/upload":
            kwargs = {
                "destination": str(request["destination"]),
                "payload_b64": str(request["content_b64"]),
                "mode": int(request.get("mode", 0o644)),
                "is_archive": bool(request.get("is_archive", False)),
                "timeout": float(request.get("timeout", 180.0)),
                "chunk_size": int(request.get("chunk_size", 262144)),
            }
            if async_job:
                return self.service.submit_job("upload", self.service.upload, **kwargs)
            return self.service.upload(**kwargs)
        if self.path == "/v1/download":
            kwargs = {
                "source": str(request["source"]),
                "recursive": bool(request.get("recursive", False)),
                "timeout": float(request.get("timeout", 180.0)),
            }
            if async_job:
                return self.service.submit_job("download", self.service.download, **kwargs)
            return self.service.download(**kwargs)
        if self.path == "/v1/terminal/start":
            rows, cols = terminal_rows_cols(request.get("rows"), request.get("cols"))
            return self.service.start_terminal(rows=rows, cols=cols)
        if self.path == "/v1/terminal/input":
            terminal = self.service.get_terminal(str(request["id"]))
            terminal.input(str(request.get("data", "")))
            return {"ok": True}
        if self.path == "/v1/terminal/read":
            terminal = self.service.get_terminal(str(request["id"]))
            return {"ok": True, "output": terminal.read(float(request.get("timeout", 1.0)))}
        if self.path == "/v1/terminal/resize":
            terminal = self.service.get_terminal(str(request["id"]))
            rows, cols = terminal_rows_cols(request.get("rows"), request.get("cols"))
            terminal.resize(rows, cols)
            return {"ok": True}
        if self.path == "/v1/terminal/close":
            self.service.close_terminal(str(request["id"]))
            return {"ok": True}
        return {"ok": False, "error": f"unknown endpoint: {self.path}"}


class TerminalStreamHandler(socketserver.BaseRequestHandler):
    service: JupyterDaemonService

    def _read_header(self) -> dict[str, Any]:
        data = b""
        while b"\n" not in data:
            chunk = self.request.recv(4096)
            if not chunk:
                raise JupyterdError("stream client closed before header")
            data += chunk
            if len(data) > 65536:
                raise JupyterdError("stream header is too large")
        line, rest = data.split(b"\n", 1)
        self._initial_input = rest
        return json.loads(line.decode("utf-8"))

    def _send_json_line(self, payload: dict[str, Any]) -> None:
        self.request.sendall(json.dumps(payload, ensure_ascii=False).encode("utf-8") + b"\n")

    def handle(self) -> None:
        terminal: LiveTerminal | None = None
        self._initial_input = b""
        try:
            request = self._read_header()
            rows, cols = terminal_rows_cols(request.get("rows"), request.get("cols"))
            terminal = self.service.open_terminal(rows=rows, cols=cols)
            initial_output = terminal.prepare_interactive_prompt()
            self._send_json_line({"ok": True, "id": terminal.id, "href": terminal.href})
            if initial_output:
                self.request.sendall(initial_output.encode("utf-8", "surrogateescape"))
            self.request.setblocking(False)
            if self._initial_input:
                terminal.input(self._initial_input.decode("utf-8", "surrogateescape"))

            while not terminal.closed:
                readable, _, _ = select.select([self.request], [], [], 0.01)
                if self.request in readable:
                    try:
                        data = self.request.recv(65536)
                    except BlockingIOError:
                        data = b""
                    if not data:
                        break
                    terminal.input(data.decode("utf-8", "surrogateescape"))

                output = terminal.read(0.0)
                if output:
                    self.request.sendall(output.encode("utf-8", "surrogateescape"))
        except Exception as exc:
            try:
                self._send_json_line({"ok": False, "error": str(exc)})
            except Exception:
                pass
        finally:
            if terminal is not None:
                terminal.close()


class ReusableThreadingTCPServer(socketserver.ThreadingTCPServer):
    allow_reuse_address = True
    daemon_threads = True


def run_server(args: argparse.Namespace) -> int:
    service = JupyterDaemonService(args)
    JupyterdRequestHandler.service = service
    TerminalStreamHandler.service = service
    server = http.server.ThreadingHTTPServer((args.listen_host, args.listen_port), JupyterdRequestHandler)
    server.daemon_threads = True
    stream_server = ReusableThreadingTCPServer((args.stream_host, args.stream_port), TerminalStreamHandler)

    stop = threading.Event()

    def maintenance_loop() -> None:
        while not stop.is_set():
            try:
                service.ensure()
            except Exception as exc:
                log(f"background maintenance failed: {exc}")
            stop.wait(args.interval)

    if args.interval > 0:
        threading.Thread(target=maintenance_loop, name="jupyterd-maintenance", daemon=True).start()

    log(f"jupyterd API listening on http://{args.listen_host}:{args.listen_port}")
    log(f"jupyterd terminal stream listening on tcp://{args.stream_host}:{args.stream_port}")
    stream_thread = threading.Thread(target=stream_server.serve_forever, name="jupyterd-stream", daemon=True)
    stream_thread.start()
    try:
        server.serve_forever()
    finally:
        stop.set()
        server.server_close()
        stream_server.shutdown()
        stream_server.server_close()
        service.close()
        stop_chrome()
    return 0


